# Port for local development (optional, defaults to 3000)
PORT=3000

# Base URL for production (without https://)
# In production, set this to your domain
# BASE_URL=yourdomain.com

# For local development, leave it empty to use http://localhost:PORT
# BASE_URL=

# init-TODO Copy this file to .env.local for local development:
# cp .env.example .env.local
# Then set BASE_URL to your production domain when deploying
